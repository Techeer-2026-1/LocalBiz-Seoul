# =================================================================
# LocalBiz Intelligence — .gitignore
# =================================================================

# ─── Secrets / 환경변수 ──────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
token.json
*.secret

# ─── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
venv/
.venv/

# ─── Cache / 린트 ────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.coverage
htmlcov/

# ─── OS ─────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
._*
Thumbs.db

# ─── IDE ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ─── 로그 / 임시 ────────────────────────────────────────────────
logs/
*.log
*.tmp
.tmp/
tmp/

# ─── 백업 ───────────────────────────────────────────────────────
*.bak
*.backup

# ─── Claude Code 로컬 설정 ──────────────────────────────────────
.claude/settings.local.json

# ─── 하네스 (sisyphus) ──────────────────────────────────────────
# plans/, notepads/, boulder.json, dependency-maps/ → 추적 (의사결정 기록)
# state/ → 휘발성 런타임 상태 → 무시
.sisyphus/state/

# ─── 레거시 아카이브 (로컬 참조 전용) ────────────────────────────
backend/_archive/

# ─── data/ — 전체 무시 (로컬 데이터 자산, repo 제외) ──────────────
data/

# ─── 대용량 바이너리 문서 ────────────────────────────────────────
docs/*.docx

# ─── graphify 산출물 ─────────────────────────────────────────────
graphify-out/
