# =================================================================
# AnyWay backend — .env.example
# 이 파일을 .env 로 복사하고 1Password "AnyWay-Dev-Shared" 값을 채운다.
# 팀원 5명 단일 공유 자격증명. 절대 .env 자체를 git에 커밋 금지.
# =================================================================

APP_ENV=development
SECRET_KEY=<from-1Password: AnyWay-Dev-Shared>

# ─── PostgreSQL (Cloud SQL — 이정 GCP 프로젝트, 팀 공유) ──────────
DB_HOST=<from-1Password>
DB_PORT=5432
DB_NAME=postgres
DB_USER=etl
DB_PASSWORD=<from-1Password>

# ─── OpenSearch (GCE — 이정 인스턴스, 팀 공유) ─────────────────────
OPENSEARCH_HOST=<from-1Password>
OPENSEARCH_PORT=9200

# ─── LLM ────────────────────────────────────────────────────────
GEMINI_LLM_API_KEY=<from-1Password>
ANTHROPIC_API_KEY=<from-1Password>

# ─── Google ─────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=<from-1Password>

# ─── Google Calendar (calendar_node — Web application OAuth) ────
# Google Cloud Console → API 및 서비스 → OAuth 클라이언트 ID (웹 애플리케이션)
# refresh_token은 .env에 없음 — 유저별로 user_oauth_tokens 테이블에서 조회
GOOGLE_CALENDAR_CLIENT_ID=<your-client-id>
GOOGLE_CALENDAR_CLIENT_SECRET=<your-client-secret>
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/calendar/callback

# ─── Naver Open API ─────────────────────────────────────────────
NAVER_CLIENT_ID=<from-1Password>
NAVER_CLIENT_SECRET=<from-1Password>

# ─── Seoul Open Data ────────────────────────────────────────────
SEOUL_API_KEY=<from-1Password>
